# Environment variables for AI News Daily
# Copy this file to .env and fill in your values

# AI Provider: openai | anthropic | google | deepseek
AI_PROVIDER=openai

# AI Model (provider-specific)
AI_MODEL=gpt-4o

# API Keys (only need the one matching your provider)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
DEEPSEEK_API_KEY=

# Product Hunt API Config (Optional - without this it falls back to RSS feed)
PRODUCTHUNT_CLIENT_ID=
PRODUCTHUNT_CLIENT_SECRET=
PRODUCTHUNT_API_TOKEN=

# Proxy (Optional - for regions with network restrictions)
# HTTPS_PROXY=http://127.0.0.1:7890

# Webhook Notification (Optional)
# WEBHOOK_URL=
# WEBHOOK_TYPE=wecom
# SITE_URL=https://your-site.com

# Google Analytics (Optional)
# PUBLIC_GA_ID=G-XXXXXXXXXX
