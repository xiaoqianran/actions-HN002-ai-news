# Environment variables for AI News Daily
# Copy this file to .env and fill in your values

# AI Provider: nvidia-nim | openai | anthropic | google | deepseek
# Default: nvidia-nim (OpenAI-compatible)
AI_PROVIDER=nvidia-nim

# AI Model (provider-specific)
# NVIDIA NIM example: stepfun-ai/step-3.5-flash
AI_MODEL=stepfun-ai/step-3.5-flash

# OpenAI-compatible endpoint (required for nvidia-nim / custom OpenAI proxies)
# Default for nvidia-nim: https://integrate.api.nvidia.com/v1
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1

# API Keys (only need the one matching your provider)
# NVIDIA NIM / OpenAI-compatible: use OPENAI_API_KEY (nvapi-xxx)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
DEEPSEEK_API_KEY=

# Product Hunt API Config (Optional - without this it falls back to RSS feed)
PRODUCTHUNT_CLIENT_ID=
PRODUCTHUNT_CLIENT_SECRET=
PRODUCTHUNT_API_TOKEN=

# Proxy (Optional - for regions with network restrictions)
# HTTPS_PROXY=http://127.0.0.1:7890

# Webhook Notification (Optional)
# WEBHOOK_URL=
# WEBHOOK_TYPE=wecom
# SITE_URL=https://your-site.com

# Google Analytics (Optional)
# PUBLIC_GA_ID=G-XXXXXXXXXX
