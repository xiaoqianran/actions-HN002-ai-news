---
interface Props {
  title: string;
  backUrl?: string;
}

const { title, backUrl } = Astro.props;
const gaId = import.meta.env.PUBLIC_GA_ID;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    {gaId && (
      <!-- Google tag (gtag.js) -->
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
      <script is:inline define:vars={{ gaId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());

        gtag('config', gaId);
      </script>
    )}
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="AI-powered daily tech news digest in English and Chinese" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <script is:inline>
      // Prevent FOUC: apply saved theme before paint
      const t = localStorage.getItem('theme');
      if (t) document.documentElement.dataset.theme = t;
    </script>
  </head>
  <body>
    <!-- Reading progress bar -->
    <div class="progress-bar" id="progress-bar"></div>

    <header>
      <nav>
        {backUrl && (
          <a href={backUrl} class="back-link js-back-link" id="nav-back-link" aria-label="返回上一页" title="返回上一页">
            <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
          </a>
        )}
        <a href="/" class="logo">AI News Daily</a>
        <span class="tagline">AI 新闻日报</span>
        <button class="theme-toggle" id="theme-toggle" aria-label="切换主题"></button>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>
        Powered by GitHub Actions + AI · Auto-generated daily
      </p>
    </footer>

    <!-- Back to top -->
    <button class="back-to-top" id="back-to-top" aria-label="回到顶部">↑</button>

    <script>
      // Theme toggle: auto → light → dark → auto
      const toggle = document.getElementById('theme-toggle');
      const icons: Record<string, string> = { light: '☀', dark: '🌙', auto: '◐' };

      function currentMode(): string {
        return document.documentElement.dataset.theme || 'auto';
      }

      function updateToggle() {
        if (toggle) toggle.textContent = icons[currentMode()] ?? icons.auto;
      }

      toggle?.addEventListener('click', () => {
        const order = ['auto', 'light', 'dark'];
        const next = order[(order.indexOf(currentMode()) + 1) % order.length];
        if (next === 'auto') {
          delete document.documentElement.dataset.theme;
          localStorage.removeItem('theme');
        } else {
          document.documentElement.dataset.theme = next;
          localStorage.setItem('theme', next);
        }
        updateToggle();
      });

      updateToggle();

      // Reading progress bar
      const progressBar = document.getElementById('progress-bar');
      const backToTop = document.getElementById('back-to-top');

      function updateProgress() {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        if (docHeight > 0 && progressBar) {
          progressBar.style.width = `${(scrollTop / docHeight) * 100}%`;
        }
        if (backToTop) {
          backToTop.classList.toggle('visible', scrollTop > 400);
        }
      }

      window.addEventListener('scroll', updateProgress, { passive: true });
      updateProgress();

      backToTop?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });

      // External links open in new tab
      document.querySelectorAll('a[href^="http"]').forEach(a => {
        if (!a.hostname.includes(location.hostname)) {
          a.setAttribute('target', '_blank');
          a.setAttribute('rel', 'noopener noreferrer');
        }
      });

      // Back navigation logic
      document.querySelectorAll('.js-back-link').forEach(link => {
        link.addEventListener('click', (e) => {
          if (window.history.length > 1 && document.referrer.includes(window.location.host)) {
            e.preventDefault();
            window.history.back();
          }
        });
      });
    </script>
  </body>
</html>

<style is:global>
  /* ========== Dark theme (default) ========== */
  :root {
    --color-bg: #0a0a0a;
    --color-surface: #141414;
    --color-border: #262626;
    --color-text: #e5e5e5;
    --color-text-muted: #a3a3a3;
    --color-accent: #3b82f6;
    --color-accent-hover: #60a5fa;
    --color-card: #1a1a1a;
    --max-width: 800px;
  }

  /* ========== Light theme (system auto) ========== */
  @media (prefers-color-scheme: light) {
    :root:not([data-theme="dark"]) {
      --color-bg: #ffffff;
      --color-surface: #f5f5f5;
      --color-border: #e0e0e0;
      --color-text: #1a1a1a;
      --color-text-muted: #666666;
      --color-accent: #2563eb;
      --color-accent-hover: #1d4ed8;
      --color-card: #f0f0f0;
    }
  }

  /* ========== Light theme (manual override) ========== */
  :root[data-theme="light"] {
    --color-bg: #ffffff;
    --color-surface: #f5f5f5;
    --color-border: #e0e0e0;
    --color-text: #1a1a1a;
    --color-text-muted: #666666;
    --color-accent: #2563eb;
    --color-accent-hover: #1d4ed8;
    --color-card: #f0f0f0;
  }

  /* ========== Dark theme (manual override) ========== */
  :root[data-theme="dark"] {
    --color-bg: #0a0a0a;
    --color-surface: #141414;
    --color-border: #262626;
    --color-text: #e5e5e5;
    --color-text-muted: #a3a3a3;
    --color-accent: #3b82f6;
    --color-accent-hover: #60a5fa;
    --color-card: #1a1a1a;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    font-size: clamp(15px, 2.5vw, 18px);
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
    background: var(--color-bg);
    color: var(--color-text);
    line-height: 1.7;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    -webkit-text-size-adjust: 100%;
    transition: background 0.2s, color 0.2s;
  }

  /* Progress bar */
  .progress-bar {
    position: fixed;
    top: 0;
    left: 0;
    height: 3px;
    width: 0;
    background: var(--color-accent);
    z-index: 100;
    transition: width 0.1s linear;
  }

  /* Back to top */
  .back-to-top {
    position: fixed;
    bottom: 2rem;
    right: 1.5rem;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);
    font-size: 1.2rem;
    cursor: pointer;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.3s, transform 0.3s;
    pointer-events: none;
    z-index: 50;
  }

  .back-to-top.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .back-to-top:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  /* Theme toggle */
  .theme-toggle {
    margin-left: auto;
    background: none;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    color: var(--color-text-muted);
    font-size: 1rem;
    width: 36px;
    height: 36px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s, color 0.2s;
    flex-shrink: 0;
  }

  .theme-toggle:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  header {
    border-bottom: 1px solid var(--color-border);
    padding: 0.75rem 1rem;
  }

  nav {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .back-link {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    transition: color 0.2s;
    margin-right: -0.25rem;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .logo {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
  }

  .logo:hover {
    color: var(--color-accent);
  }

  .tagline {
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }

  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1.5rem 1rem;
    flex: 1;
    width: 100%;
  }

  footer {
    border-top: 1px solid var(--color-border);
    padding: 1.25rem 1rem;
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.75rem;
  }

  a {
    color: var(--color-accent);
    text-decoration: none;
  }

  a:hover {
    color: var(--color-accent-hover);
    text-decoration: underline;
  }

  h1, h2, h3 {
    line-height: 1.3;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  h1 { font-size: 1.75rem; }
  h2 { font-size: 1.3rem; border-bottom: 1px solid var(--color-border); padding-bottom: 0.5rem; }
  h3 { font-size: 1.05rem; color: var(--color-text); }

  p {
    margin-bottom: 0.75rem;
  }

  hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  blockquote {
    border-left: 3px solid var(--color-accent);
    padding-left: 1rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  ul, ol {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  li {
    margin-bottom: 0.25rem;
  }

  code {
    background: var(--color-surface);
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
    font-size: 0.9em;
  }

  /* Mobile touch targets */
  @media (max-width: 640px) {
    main {
      padding: 1rem 0.75rem;
    }

    h2 {
      font-size: 1.15rem;
    }

    h3 {
      font-size: 1rem;
    }

    .back-to-top {
      bottom: 1.25rem;
      right: 1rem;
    }
  }
</style>
