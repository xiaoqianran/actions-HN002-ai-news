---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('news');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={post.data.title} backUrl="/">
  <article class="news-detail">
    <header class="news-header">
      <h1>{post.data.title}</h1>
      <div class="news-meta">
        <a href={post.data.originalUrl} target="_blank" rel="noopener noreferrer" class="meta-link original-link">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          查看原文 / View Original
        </a>
        <a href={`https://github.com/tianyaxiang/ai-news/edit/main/src/content/news/${post.id}.md`} target="_blank" rel="noopener noreferrer" class="meta-link edit-link">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          编辑 / Edit
        </a>
      </div>
    </header>

    <div class="news-content">
      <Content />
    </div>
    
    <div class="news-footer">
      <a href="/" class="back-link js-back-link">← 返回新闻列表 / Back to news list</a>
    </div>
  </article>
</Layout>

<style>
  .news-detail {
    max-width: var(--max-width);
    margin: 0 auto;
  }
  .news-header {
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }
  .news-header h1 {
    font-size: 1.8rem;
    margin-bottom: 0.5rem;
  }
  .news-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
  .meta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.3rem 0.7rem;
    border-radius: 6px;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    text-decoration: none;
    transition: all 0.2s ease;
    color: var(--color-text-muted);
  }
  .meta-link:hover {
    text-decoration: none;
  }
  .meta-link svg {
    flex-shrink: 0;
  }
  .original-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .edit-link:hover {
    border-color: #2ea44f;
    color: #2ea44f;
    background: rgba(46, 164, 79, 0.06);
  }
  .news-content {
    line-height: 1.8;
  }
  .news-content :global(p) {
    margin-bottom: 1.25rem;
  }
  .news-footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    text-align: center;
  }
  .back-link {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.2s;
  }
  .back-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>
